    "dev": "node --env-file=.env --experimental-sqlite --watch src/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "express": "^4.19.2",
    "playwright": "^1.44.1"
  }
}
