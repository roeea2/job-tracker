{
  "name": "roee-job-tracker",
  "version": "1.0.0",
  "description": "LinkedIn job scraper + CV customizer + dashboard for Roee Aizman",
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env --experimental-sqlite src/server.js",
    "scrape": "node --env-file=.env --experimental-sqlite src/scraper.js",
